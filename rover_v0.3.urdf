<?xml version="1.0"?>
<robot name="custom_rover">

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="acrylic_clear">
    <color rgba="0.8 0.9 1.0 0.4"/>
  </material>

  <link name="base_link"/>

  <link name="chassis">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.9 0.6 0.15"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>
  
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="top_acrylic">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.95 0.65 0.01"/>
      </geometry>
      <material name="acrylic_clear"/>
    </visual>
  </link>

  <joint name="chassis_to_acrylic" type="fixed">
    <parent link="chassis"/>
    <child link="top_acrylic"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="fl_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="fl_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="fl_wheel"/>
    <origin xyz="0.3 0.35 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="fr_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="fr_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="fr_wheel"/>
    <origin xyz="0.3 -0.35 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rl_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rl_wheel_joint
