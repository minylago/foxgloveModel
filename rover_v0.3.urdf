<?xml version="1.0"?>
<robot name="custom_rover">

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="acrylic_clear">
    <color rgba="0.8 0.9 1.0 0.4"/>
  </material>
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <link name="base_link">
  </link>

  <link name="chassis">
    <visual>
      <geometry>
        <box size="0.9 0.6 0.15"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>
  
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="top_acrylic">
    <visual>
      <geometry>
        <box size="0.95 0.65 0.01"/>
      </geometry>
      <material name="acrylic_clear"/>
    </visual>
  </link>

  <joint name="chassis_to_acrylic" type="fixed">
    <parent link="chassis"/>
    <child link="top_acrylic"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="fl_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="fl_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="fl_wheel"/>
    <origin xyz="0.3 0.35 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="fr_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="fr_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="fr_wheel"/>
    <origin xyz="0.3 -0.35 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rl_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rl_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rl_wheel"/>
    <origin xyz="-0.3 0.35 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rr_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.13" length="0.12"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="rr_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rr_wheel"/>
    <origin xyz="-0.3 -0.35 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_lidar">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="chassis_to_left_lidar" type="fixed">
    <parent link="chassis"/>
    <child link="left_lidar"/>
    <origin xyz="0 0.32 0.08" rpy="0 0 0"/>
  </joint>

  <link name="right_lidar">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="chassis_to_right_lidar" type="fixed">
    <parent link="chassis"/>
    <child link="right_lidar"/>
    <origin xyz="0 -0.32 0.08" rpy="0 0 0"/>
  </joint>

  <link name="front_camera_top">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="chassis_to_camera_top" type="fixed">
    <parent link="chassis"/>
    <child name="front_camera_top"/>
    <origin xyz="0.47 0 0.08" rpy="0 0 0"/>
  </joint>

  <link name="front_sensor_box">
    <visual>
      <geometry>
        <box size="0.04 0.18 0.12"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>
  <joint name="chassis_to_sensor_box" type="fixed">
    <parent link="chassis"/>
    <child link="front_sensor_box"/>
    <origin xyz="0.48 0 0" rpy="0 0 0"/>
  </joint>

</robot>
