  </joint>

  <link name="front_radar">
    <visual>
      <geometry>
        <box size="0.05 0.15 0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="chassis_to_front_radar" type="fixed">
    <parent link="chassis"/>
    <child link="front_radar"/>
    <origin xyz="0.52 0 0.05" rpy="0 0 0"/>
  </joint>

</robot>
