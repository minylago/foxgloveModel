<?xml version="1.0"?>
<robot name="custom_rover">

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="acrylic_clear">
    <color rgba="0.8 0.9 1.0 0.3"/> 
  </material>
  <material name="sensor_blue">
    <color rgba="0.1 0.3 0.8 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>

  <link name="base_link">
  </link>

  <link name="chassis">
    <visual>
      <geometry>
        <box size="1.0 0.6 0.2"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>
  
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="fl_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.10" length="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.09"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0.045 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.045 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 0.045 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 -0.045 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>
  <joint name="fl_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="fl_wheel"/>
    <origin xyz="0.35 0.28 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="fr_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.10" length="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.09"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0.045 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.045 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 0.045 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 -0.045 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>
  <joint name="fr_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="fr_wheel"/>
    <origin xyz="0.35 -0.28 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rl_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.10" length="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.09"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0.045 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.045 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 0.045 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 -0.045 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>
  <joint name="rl_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rl_wheel"/>
    <origin xyz="-0.35 0.28 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="rr_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.10" length="0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.09"/>
      </geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0.045 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="-0.045 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 0.045 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <visual>
      <origin xyz="0 -0.045 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.085"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>
  <joint name="rr_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="rr_wheel"/>
    <origin xyz="-0.35 -0.28 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_lidar">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="chassis_to_left_lidar" type="fixed">
    <parent link="chassis"/>
    <child link="left_lidar"/>
    <origin xyz="0.1 0.25 0.11" rpy="0 0 0"/>
  </joint>

  <link name="right_lidar">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="chassis_to_right_lidar" type="fixed">
