<?xml version="1.0"?>
<robot name="custom_rover">

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="acrylic_clear">
    <color rgba="0.8 0.9 1.0 0.3"/> 
  </material>
  <material name="sensor_blue">
    <color rgba="0.1 0.3 0.8 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="orange">
    <color rgba="0.9 0.5 0.1 1.0"/>
  </material>

  <link name="base_link">
  </link>

  <link name="chassis">
    <visual>
      <geometry>
        <box size="1.0 0.6 0.2"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
  </link>
  
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>
  
  <link name="top_front_left_box_RPiv5">
    <visual>
      <geometry><box size="0.08 0.23 0.05"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="chassis_to_tfl_box" type="fixed">
    <parent link="chassis"/>
    <child link="top_front_left_box_RPiv5"/>
    <origin xyz="0.35 0.13 0.125" rpy="0 0 0"/>
  </joint>

  <link name="top_front_right_box_RPiv5">
    <visual>
      <geometry><box size="0.08 0.23 0.05"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="chassis_to_tfr_box" type="fixed">
    <parent link="chassis"/>
    <child link="top_front_right_box_RPiv5"/>
    <origin xyz="0.35 -0.13 0.125" rpy="0 0 0"/>
  </joint>

  <link name="top_front_camera">
    <visual>
      <geometry><box size="0.03 0.04 0.04"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="-0.05 0 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.08 0.02 0.002"/></geometry>
      <material name="orange"/>
    </visual>
  </link>
  <joint name="chassis_to_top_front_camera" type="fixed">
    <parent link="chassis"/>
    <child link="top_front_camera"/>
    <origin xyz="0.48 -0.05 0.12" rpy="0 0 0"/>
  </joint>

  <link name="top_rear_camera">
    <visual>
      <geometry><box size="0.03 0.04 0.04"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="-0.05 0 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.08 0.02 0.002"/></geometry>
      <material name="orange"/>
    </visual>
  </link>
  <joint name="chassis_to_top_rear_camera" type="fixed">
    <parent link="chassis"/>
    <child link="top_rear_camera"/>
    <origin xyz="-0.48 -0.05 0.12" rpy="0 0 3.14159"/>
  </joint>

  <link name="top_rear_CANgateway_RearCAM">
    <visual>
      <geometry><box size="0.09 0.05 0.03"/></geometry>
      <material name="white"/>
    </visual>
    <visual>
      <origin xyz="-0.055 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.015 0.01"/></geometry>
      <material name="orange"/>
    </visual>
  </link>
  <joint name="chassis_to_trl_gateway" type="fixed">
    <parent link="chassis"/>
    <child link="top_rear_CANgateway_RearCAM"/>
    <origin xyz="-0.35 -0.05 0.115" rpy="0 0 0"/>
  </joint>

